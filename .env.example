# ─── Schul-Netz Login ─────────────────────────────────────────────────────────
# Your Schul-Netz username and password
SN_USER=your.username
SN_PASS=YourPassword123

# The full URL to your school's Schul-Netz grades page (pageid=21311 is specific
# to each school – get it from the URL in your browser after logging in)
TARGET_URL=https://www.schul-netz.com/yourschool/index.php?pageid=12345

# ─── Email Notifications (optional) ──────────────────────────────────────────
# Leave these blank if you don't want email notifications.
#
# Gmail: use an App Password, NOT your real Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Comma-separated list of email addresses to send grade alerts to
RECIPIENTS=you@example.com,friend@example.com

# ─── Check Interval ───────────────────────────────────────────────────────────
# How often to check for new grades, in minutes (default: 15)
CHECK_INTERVAL=15
